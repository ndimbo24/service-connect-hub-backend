PORT=8080
DB_URL=jdbc:postgresql://localhost:5432/service_connect_hub
DB_USERNAME=postgres
DB_PASSWORD=postgres
# Railway Postgres services expose PGHOST, PGPORT, PGDATABASE, PGUSER and PGPASSWORD automatically.
# You usually do not need DB_URL/DB_USERNAME/DB_PASSWORD on Railway unless you are using an external database.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=86400000
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
APP_ADMIN_SEED_ENABLED=true
APP_ADMIN_NAME=System Admin
APP_ADMIN_PHONE=1111111111
APP_ADMIN_EMAIL=admin@serviceconnect.com
APP_ADMIN_PASSWORD=admin123
APP_LOG_LEVEL=INFO
